  "schemaVersion": 39,
  "templating": {
    "list": [
      {
        "current": { "selected": true, "text": "All", "value": "$__all" },
        "datasource": { "type": "prometheus", "uid": "prometheus" },
        "definition": "label_values(gen_ai_client_token_usage_sum, gen_ai_request_model)",
        "includeAll": true,
        "multi": true,
        "name": "model",
        "query": {
          "qryType": 1,
          "query": "label_values(gen_ai_client_token_usage_sum, gen_ai_request_model)"
        },
        "refresh": 2,
        "regex": "",
        "type": "query"
      }
