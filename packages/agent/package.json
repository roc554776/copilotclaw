{
  "name": "@copilotclaw/agent",
  "version": "0.7.0",
  "description": "CLI agent powered by GitHub Copilot SDK",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "dev": "tsc && node dist/index.js",
    "stop": "node dist/stop.js",
    "test": "vitest run"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "private": true,
  "dependencies": {
    "@github/copilot-sdk": "^0.2.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
