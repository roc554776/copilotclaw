{
  "name": "@copilotclaw/gateway",
  "version": "0.30.0",
  "description": "Central gateway server for copilotclaw",
  "type": "module",
  "main": "dist/index.js",
  "files": [
    "dist/",
    "package.json"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "stop": "node dist/stop.js",
    "restart": "node dist/restart.js",
    "setup": "node dist/setup.js",
    "update": "node dist/update.js",
    "dev": "tsc && node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:e2e": "vitest run test/e2e",
    "test:browser": "playwright test"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  },
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  }
}
