{
  "name": "@copilotclaw/gateway",
  "version": "0.1.0",
  "description": "Central gateway server for copilotclaw",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "stop": "node dist/stop.js",
    "setup": "node dist/setup.js",
    "update": "node dist/update.js",
    "dev": "tsc && node dist/index.js",
    "test": "vitest run",
    "test:unit": "vitest run test/unit",
    "test:e2e": "vitest run test/e2e"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "private": true,
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^6.0.2",
    "vitest": "^4.1.1"
  }
}
